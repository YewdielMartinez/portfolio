---
import '../styles/global.css';
---

<!doctype html>
<html lang="en" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>Yewdiel Medina - Developer Portfolio</title>
		<script is:inline>
			if (localStorage.getItem('theme') === 'dark') {
				document.documentElement.classList.add('dark');
			} else {
				document.documentElement.classList.remove('dark');
			}
		</script>
	</head>
	<body class="text-gray-900 dark:text-white transition-colors duration-300">
		<slot />
	</body>
</html>

<style is:global>
	body {
		font-family: 'NB International', sans-serif;
		background-color: rgb(240, 238, 230);
	}

	.dark body {
		background-color: rgb(38, 38, 36);
	}

	h1, h2, h3, h4, h5, h6 {
		font-family: 'NB International', sans-serif;
		font-weight: 400;
		letter-spacing: -0.02em;
	}

	/* View Transitions */
	:root {
		view-transition-name: none;
	}

	::view-transition {
		pointer-events: none;
	}

	::view-transition-group(vt-element-animation),
	::view-transition-group(vt-element-animation-closing) {
		animation-duration: 500ms;
		animation-timing-function: cubic-bezier(0.38, 0.49, 0, 1);
	}

	::view-transition-old(vt-element-animation),
	::view-transition-new(vt-element-animation),
	::view-transition-old(vt-element-animation-closing),
	::view-transition-new(vt-element-animation-closing) {
		height: 100%;
		min-height: 100%;
		overflow: clip;
		object-position: left top;
	}

	@keyframes vt-fade-in {
		from { opacity: 0; }
	}

	@keyframes vt-fade-out {
		to { opacity: 0; }
	}

	::view-transition-old(vt-element-animation) {
		animation: vt-fade-out 200ms both cubic-bezier(0.38, 0.49, 0, 1);
	}

	::view-transition-new(vt-element-animation) {
		animation: vt-fade-in 200ms both cubic-bezier(0.38, 0.49, 0, 1);
	}

	::view-transition-old(vt-element-animation-closing) {
		animation: vt-fade-in 200ms both cubic-bezier(0.75, 0, 0.41, -0.06);
	}

	::view-transition-new(vt-element-animation-closing) {
		animation: vt-fade-out 200ms both cubic-bezier(0.75, 0, 0.41, -0.06);
	}
</style>

<script>
	// Initialize language from localStorage or default to English
	if (!localStorage.getItem('language')) {
		localStorage.setItem('language', 'en');
	}
</script>

<script>
	import gsap from 'gsap';
	import { ScrollTrigger } from 'gsap/ScrollTrigger';

	gsap.registerPlugin(ScrollTrigger);

	document.addEventListener('DOMContentLoaded', () => {
		// ── Contact section reveals ──────────────────────────────
		const contactHeading = document.querySelector<HTMLElement>('#contact h2');
		if (contactHeading) {
			gsap.fromTo(
				contactHeading,
				{ opacity: 0, y: 40, filter: 'blur(8px)' },
				{
					opacity: 1, y: 0, filter: 'blur(0px)',
					duration: 0.9, ease: 'power3.out',
					scrollTrigger: { trigger: contactHeading, start: 'top 82%', once: true },
				}
			);
		}

		const contactSubtitle = document.querySelector<HTMLElement>('#contact > div > p');
		if (contactSubtitle) {
			gsap.fromTo(
				contactSubtitle,
				{ opacity: 0, y: 20 },
				{
					opacity: 1, y: 0,
					duration: 0.65, ease: 'power2.out',
					scrollTrigger: { trigger: contactSubtitle, start: 'top 84%', once: true },
				}
			);
		}

		// Stagger form fields in
		const formFields = document.querySelectorAll('#contact-form .mb-6');
		if (formFields.length) {
			gsap.set(formFields, { opacity: 0, y: 20 });
			gsap.to(formFields, {
				opacity: 1, y: 0,
				duration: 0.55, ease: 'power2.out',
				stagger: 0.1,
				scrollTrigger: { trigger: '#contact-form', start: 'top 80%', once: true },
			});
		}

		const submitBtn = document.getElementById('submit-button');
		if (submitBtn) {
			gsap.set(submitBtn, { opacity: 0, y: 12 });
			gsap.to(submitBtn, {
				opacity: 1, y: 0,
				duration: 0.5, ease: 'back.out(1.2)',
				scrollTrigger: { trigger: '#contact-form', start: 'top 72%', once: true },
			});
		}
	});
</script>
