---
// Sección "Sobre Mí" 
import SkillIcon from './SkillIcon';
import { skills } from '../data/skills';
---

<section 
  id="about" 
  class="py-24 px-4 bg-gray-50 dark:bg-black transition-colors duration-300"
>
  <div class="max-w-6xl mx-auto">
    <h2 
      class="text-4xl md:text-5xl font-bold text-center mb-16"
      data-i18n="about.title"
    >
      About Me
    </h2>
    
    <div class="grid md:grid-cols-2 gap-12 items-center mb-16">
      <!-- Foto de perfil -->
      <div class="flex justify-center md:justify-end">
        <div class="w-64 h-64 rounded-full overflow-hidden bg-gray-300 dark:bg-gray-700 border-4 border-gray-200 dark:border-gray-700 shadow-xl hover:scale-105 hover:rotate-3 transition-all duration-500 hover:shadow-2xl hover:shadow-black/20 animate-fade-in">
          <img 
            id="about-avatar"
            src="/avatar.jpg" 
            alt="Profile"
            class="w-full h-full object-cover hover:scale-110 transition-transform duration-500"
          />
        </div>
      </div>
      
      <!-- Biografía -->
      <div class="space-y-6">
        <p 
          class="text-lg text-gray-700 dark:text-gray-300 leading-relaxed mb-6"
          data-i18n="about.bio"
        >
          I'm a passionate developer who loves creating beautiful, functional applications. With expertise in modern web technologies, I focus on delivering exceptional user experiences and clean, maintainable code.
        </p>
        
        <!-- Letterboxd Link -->
        <a 
          href="https://letterboxd.com" 
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-6 py-3 bg-black dark:bg-white text-white dark:text-black rounded-full transition-all duration-300 hover:scale-105 hover:bg-gray-800 dark:hover:bg-gray-100 hover:shadow-xl hover:shadow-black/20 font-semibold"
        >
          <svg class="w-5 h-5" viewBox="0 0 500 500" fill="currentColor">
            <circle cx="125" cy="250" r="115" opacity="0.8"/>
            <circle cx="375" cy="250" r="115" opacity="0.8"/>
          </svg>
          <span>My Letterboxd</span>
        </a>
      </div>
    </div>
    
    <!-- Skills Section -->
    <div class="mb-20">
      <h3 
        class="text-2xl font-bold mb-8 text-center"
        data-i18n="about.skillsTitle"
      >
        Skills & Technologies
      </h3>
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 gap-4 md:gap-6">
        {skills.map((skill, index) => (
          <div style={`animation: fade-in-up 0.5s ease-out ${index * 0.03}s both`}>
            <SkillIcon 
              client:load
              iconPath={skill.icon}
              color={skill.color}
              name={skill.name}
            />
          </div>
        ))}
      </div>
    </div>

  </div>
</section>

<style>
  @keyframes fade-in-up {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  
  @keyframes float {
    0%, 100% {
      transform: translateY(0px) rotate(0deg);
    }
    50% {
      transform: translateY(-20px) rotate(5deg);
    }
  }
  
  @keyframes float-reverse {
    0%, 100% {
      transform: translateY(0px) rotate(0deg);
    }
    50% {
      transform: translateY(20px) rotate(-5deg);
    }
  }
  
  .animate-float {
    animation: float 4s ease-in-out infinite;
  }
  
  .animate-float-reverse {
    animation: float-reverse 5s ease-in-out infinite;
  }
  
  @keyframes fade-in {
    from {
      opacity: 0;
      transform: scale(0.95);
    }
    to {
      opacity: 1;
      transform: scale(1);
    }
  }
  
  .animate-fade-in {
    animation: fade-in 0.8s ease-out;
  }
  
  /* Efecto de brillo al pasar el mouse sobre la sección de cine */
  .cinema-glow:hover {
    box-shadow: 0 0 30px rgba(245, 73, 39, 0.4);
  }

  /* Animaciones de la presentación */
  @keyframes slideIn {
    from {
      opacity: 0;
      transform: scale(0.95) translateY(20px);
    }
    to {
      opacity: 1;
      transform: scale(1) translateY(0);
    }
  }

  .slide-in {
    animation: slideIn 0.6s ease-out;
  }

  @keyframes pulse-dot {
    0%, 100% {
      opacity: 0.5;
      transform: scale(1);
    }
    50% {
      opacity: 1;
      transform: scale(1.2);
    }
  }
</style>

<script>
  async function loadAbout() {
    const { avatar } = await import('../data/translations');
    
    // Actualizar avatar
    const avatarImg = document.getElementById('about-avatar') as HTMLImageElement;
    if (avatarImg) {
      avatarImg.src = avatar;
    }
  }
  
  // Actualizar al cambiar de idioma
  window.addEventListener('languageChange', (event: any) => {
    const { translations } = event.detail;
    
    // Actualizar elementos de texto
    ['about.bio', 'about.skillsTitle'].forEach(key => {
      const element = document.querySelector(`[data-i18n="${key}"]`);
      if (element) {
        const keys = key.split('.');
        let value: any = translations;
        for (const k of keys) {
          value = value[k];
        }
        if (value) {
          element.textContent = value;
        }
      }
    });
    
    // Actualizar título
    const title = document.querySelector('[data-i18n="about.title"]');
    if (title) {
      title.textContent = translations.about.title;
    }
  });
  
  // Carga inicial
  loadAbout();
</script>
