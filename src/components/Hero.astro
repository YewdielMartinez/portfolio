---
---

<section id="home" class="relative min-h-screen flex items-center px-6 sm:px-10 lg:px-20 pt-20 pb-16 overflow-hidden">

  <!-- Main content -->
  <div class="w-full max-w-6xl relative" style="z-index: 10;">

    <!-- Structural anchor rule -->
    <div id="hero-rule" class="mb-10 h-px bg-gray-900 dark:bg-white opacity-15"></div>

    <!-- Primary: Name -->
    <div class="mb-8">
      <h1
        class="font-normal text-gray-900 dark:text-white select-none"
        style="font-size: clamp(4rem, 11vw, 10rem); line-height: 0.9; letter-spacing: -0.04em;"
        aria-label="Yewdiel Medina"
      >
        <span class="name-clip"><span id="name-l1">Yewdiel</span></span>
        <span class="name-clip"><span id="name-l2">Medina.</span></span>
      </h1>
    </div>

    <!-- Role + extending line -->
    <div id="hero-meta" class="flex items-center gap-5 mb-14">
      <p
        id="hero-role"
        class="text-[10px] font-medium tracking-[0.25em] uppercase text-gray-400 dark:text-gray-500 shrink-0"
      ></p>
      <div
        id="role-line"
        class="flex-1 h-px bg-gray-200 dark:bg-gray-700/60"
        aria-hidden="true"
      ></div>
    </div>

    <!-- CTAs -->
    <div id="hero-buttons" class="flex flex-col sm:flex-row gap-3 mb-12">
      <a
        href="#work"
        class="inline-flex items-center justify-center gap-2.5 px-8 py-3.5 bg-gray-900 dark:bg-white text-white dark:text-black rounded-full text-sm tracking-wide transition-all duration-300 hover:bg-gray-700 dark:hover:bg-gray-100 group"
        aria-label="View my work"
      >
        <span id="btn-view-work">View Work</span>
        <svg class="w-3.5 h-3.5 transition-transform duration-300 group-hover:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
        </svg>
      </a>
      <a
        href="#contact"
        id="btn-contact"
        class="inline-flex items-center justify-center px-8 py-3.5 border border-gray-300 dark:border-gray-600 text-gray-600 dark:text-gray-300 rounded-full text-sm tracking-wide transition-all duration-300 hover:border-gray-700 dark:hover:border-gray-400 hover:text-gray-900 dark:hover:text-white"
      >
        Contact
      </a>
    </div>

    <!-- Social links -->
    <div id="hero-social" class="flex items-center gap-3">
      <div id="hero-social-links" class="flex gap-2"></div>
      <div class="w-px h-4 bg-gray-200 dark:bg-gray-700 mx-0.5 shrink-0" aria-hidden="true"></div>
      <a
        href="/CV.pdf"
        download
        class="w-10 h-10 flex items-center justify-center border border-gray-300 dark:border-gray-600 text-gray-400 dark:text-gray-500 rounded-full transition-all duration-300 hover:bg-gray-900 dark:hover:bg-white hover:text-white dark:hover:text-black hover:border-gray-900 dark:hover:border-white"
        aria-label="Download CV"
        title="Download CV"
      >
        <svg class="w-[15px] h-[15px]" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
        </svg>
      </a>
    </div>

  </div>

  <!-- Right descriptor — desktop only -->
  <div
    id="hero-right"
    class="hidden lg:flex flex-col items-end gap-4 absolute right-6 sm:right-10 lg:right-20 top-1/2 -translate-y-1/2 pointer-events-none"
    style="z-index: 10;"
    aria-hidden="true"
  >
    <div class="flex flex-col items-end gap-2.5">
      <span class="right-tag text-[9px] font-medium tracking-[0.22em] uppercase text-gray-300 dark:text-gray-600">Design Systems</span>
      <span class="right-tag text-[9px] font-medium tracking-[0.22em] uppercase text-gray-300 dark:text-gray-600">UI Design</span>
      <span class="right-tag text-[9px] font-medium tracking-[0.22em] uppercase text-gray-300 dark:text-gray-600">UX Research</span>
      <span class="right-tag text-[9px] font-medium tracking-[0.22em] uppercase text-gray-300 dark:text-gray-600">Frontend Dev</span>
    </div>
    <div id="right-divider" class="w-px bg-gray-200 dark:bg-gray-700" style="height: 32px;"></div>
    <span id="right-year" class="text-[9px] font-medium tracking-[0.2em] text-gray-300 dark:text-gray-600">2025</span>
  </div>

  <!-- Scroll cue -->
  <div
    id="scroll-indicator"
    class="absolute bottom-8 right-6 sm:right-10 lg:right-20 flex flex-col items-center gap-3 pointer-events-none"
    style="z-index: 10;"
    aria-hidden="true"
  >
    <span
      class="text-[9px] font-medium tracking-[0.3em] uppercase text-gray-400 dark:text-gray-400"
      style="writing-mode: vertical-rl; text-orientation: mixed;"
    >Scroll</span>
    <div id="scroll-line" class="w-px bg-linear-to-b from-gray-400 dark:from-gray-400 to-transparent" style="height: 48px;"></div>
  </div>

</section>

<style>
  /* Initial states */
  #hero-rule         { transform: scaleX(0); transform-origin: left center; }
  #hero-meta         { opacity: 0; }
  #role-line         { transform: scaleX(0); transform-origin: left center; }
  #hero-buttons      { opacity: 0; transform: translateY(16px); }
  #hero-social       { opacity: 0; }
  #scroll-indicator  { opacity: 0; }
  .right-tag         { opacity: 0; transform: translateX(10px); }
  #right-divider     { opacity: 0; transform: scaleY(0); transform-origin: top center; }
  #right-year        { opacity: 0; }

  /* Name reveal */
  .name-clip          { display: block; overflow: hidden; line-height: 1.0; }
  #name-l1, #name-l2 { display: block; transform: translateY(108%); }

  /* Scroll line */
  @keyframes scroll-pulse {
    0%, 100% { opacity: 0.25; }
    50%       { opacity: 0.7; }
  }
  #scroll-line { animation: scroll-pulse 2.8s ease-in-out infinite; }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  import { translations, social } from '../data/translations';

  gsap.registerPlugin(ScrollTrigger);

  type Lang = 'en' | 'es';

  const SOCIAL_BTN =
    'w-10 h-10 flex items-center justify-center border border-gray-300 dark:border-gray-600 ' +
    'text-gray-400 dark:text-gray-500 rounded-full transition-all duration-300 ' +
    'hover:bg-gray-900 dark:hover:bg-white hover:text-white dark:hover:text-black ' +
    'hover:border-gray-900 dark:hover:border-white';

  function el(id: string): HTMLElement | null {
    return document.getElementById(id);
  }

  function applyTexts(t: typeof translations['en']) {
    const role     = el('hero-role');
    const viewWork = el('btn-view-work');
    const contact  = el('btn-contact');
    if (role)     role.textContent     = t.home.role;
    if (viewWork) viewWork.textContent = t.home.viewWork;
    if (contact)  contact.textContent  = t.home.contactMe;
  }

  function resetStates() {
    gsap.set('#hero-rule',          { scaleX: 0 });
    gsap.set('#name-l1, #name-l2',  { y: '108%' });
    gsap.set('#hero-meta',          { opacity: 0 });
    gsap.set('#role-line',          { scaleX: 0 });
    gsap.set('#hero-buttons',       { opacity: 0, y: 16 });
    gsap.set('#hero-social',        { opacity: 0 });
    gsap.set('#scroll-indicator',   { opacity: 0 });
    gsap.set('.right-tag',          { opacity: 0, x: 10 });
    gsap.set('#right-divider',      { opacity: 0, scaleY: 0 });
    gsap.set('#right-year',         { opacity: 0 });
  }

  let heroTL: gsap.core.Timeline | null = null;
  let parallaxST: ScrollTrigger | null = null;

  function setupParallax() {
    if (parallaxST) { parallaxST.kill(); parallaxST = null; }
    const tl = gsap.timeline({ paused: true })
      .to(['#name-l1', '#name-l2'], { y: -80,              ease: 'none' }, 0)
      .to('#hero-rule',             { opacity: 0,           ease: 'none' }, 0)
      .to('#hero-meta',             { y: -40, opacity: 0,   ease: 'none' }, 0)
      .to('#hero-buttons',          { y: -25, opacity: 0,   ease: 'none' }, 0)
      .to('#hero-social',           { opacity: 0,           ease: 'none' }, 0)
      .to(['.right-tag', '#right-divider', '#right-year'], { x: 20, opacity: 0, ease: 'none' }, 0);
    parallaxST = ScrollTrigger.create({
      trigger: '#home',
      start: 'top top',
      end: 'bottom top',
      scrub: 1.2,
      animation: tl,
    });
  }

  function buildTimeline() {
    heroTL = gsap.timeline({ defaults: { ease: 'power3.out' }, onComplete: setupParallax })
      // Anchor rule draws in
      .to('#hero-rule',        { scaleX: 1,        duration: 1.0, ease: 'power3.inOut'  }, 0.1)
      // Name slides up — staggered lines
      .to('#name-l1',          { y: '0%',           duration: 1.1, ease: 'power4.out'   }, 0.45)
      .to('#name-l2',          { y: '0%',           duration: 1.1, ease: 'power4.out'   }, 0.58)
      // Role text fades in
      .to('#hero-meta',        { opacity: 1,         duration: 0.5                       }, 0.9)
      // Line extends from role
      .to('#role-line',        { scaleX: 1,          duration: 0.9, ease: 'power3.inOut' }, 0.95)
      // Right descriptor staggered from right edge
      .to('.right-tag',        { opacity: 1, x: 0,   duration: 0.5, stagger: 0.08       }, 1.0)
      .to('#right-divider',    { opacity: 1, scaleY: 1, duration: 0.5                   }, 1.42)
      .to('#right-year',       { opacity: 1,           duration: 0.5                     }, 1.6)
      // CTAs + socials
      .to('#hero-buttons',     { opacity: 1, y: 0,   duration: 0.55                     }, 1.15)
      .to('#hero-social',      { opacity: 1,           duration: 0.5                     }, 1.3)
      // Scroll cue last
      .to('#scroll-indicator', { opacity: 1,           duration: 0.6                     }, 1.9);
  }

  function renderSocials() {
    const container = el('hero-social-links');
    if (!container) return;

    const items: string[] = [];

    if (social.github) items.push(`
      <a href="${social.github}" target="_blank" rel="noopener noreferrer" class="${SOCIAL_BTN}" aria-label="GitHub">
        <svg width="15" height="15" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
        </svg>
      </a>`);

    if (social.linkedin) items.push(`
      <a href="${social.linkedin}" target="_blank" rel="noopener noreferrer" class="${SOCIAL_BTN}" aria-label="LinkedIn">
        <svg width="15" height="15" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
        </svg>
      </a>`);

    if (social.twitter) items.push(`
      <a href="${social.twitter}" target="_blank" rel="noopener noreferrer" class="${SOCIAL_BTN}" aria-label="X (Twitter)">
        <svg width="15" height="15" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
        </svg>
      </a>`);

    if (social.email) items.push(`
      <a href="mailto:${social.email}" class="${SOCIAL_BTN}" aria-label="Email">
        <svg width="15" height="15" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
        </svg>
      </a>`);

    container.innerHTML = items.join('');
  }

  document.addEventListener('DOMContentLoaded', () => {
    const lang = (localStorage.getItem('language') || 'en') as Lang;
    applyTexts(translations[lang]);
    renderSocials();

    resetStates();
    buildTimeline();

    const scrollInd = el('scroll-indicator');
    if (scrollInd) {
      window.addEventListener('scroll', () => {
        gsap.to(scrollInd, {
          opacity: window.scrollY > 80 ? 0 : 1,
          duration: 0.4,
          overwrite: true,
        });
      }, { passive: true });
    }
  });

  window.addEventListener('languageChange', async (event: any) => {
    const t = event.detail.translations as typeof translations['en'];

    const outTL = gsap.timeline();
    outTL
      .to(['#name-l2', '#name-l1'],
          { y: '-108%', duration: 0.4, stagger: 0.07, ease: 'power3.in' }, 0)
      .to(['#hero-social', '#hero-buttons', '#hero-meta'],
          { opacity: 0, y: -8, duration: 0.2, stagger: 0.04 }, 0)
      .to('.right-tag',   { opacity: 0, x: 8, duration: 0.2 }, 0)
      .to('#hero-rule',   { scaleX: 0, duration: 0.4, ease: 'power2.in' }, 0.1);

    await outTL.then();
    applyTexts(t);
    if (heroTL) heroTL.kill();
    if (parallaxST) { parallaxST.kill(); parallaxST = null; }
    resetStates();
    buildTimeline();
  });
</script>
