---
// Hero Section
---

<section id="home" class="relative min-h-screen flex items-center justify-center px-4 sm:px-8 lg:px-16 pt-16">
  <div class="max-w-3xl mx-auto w-full text-center">

    <!-- Name -->
    <div class="mb-3 flex justify-center">
      <h1
        id="name-line"
        class="font-bold leading-[0.9] tracking-tight transition-colors duration-300 hover:text-gray-500 dark:hover:text-gray-400 cursor-default text-left"
        style="font-size: clamp(3rem, 8.5vw, 8rem); opacity: 0;"
      ><span class="typing-text"></span><span class="typing-cursor">|</span></h1>
    </div>

    <!-- Role -->
    <p
      id="hero-role"
      class="text-xl sm:text-2xl lg:text-3xl text-gray-500 dark:text-gray-400 mb-2 font-normal text-center"
      data-i18n="home.role"
      style="opacity: 0; transform: translateY(10px); transition: opacity 0.5s ease, transform 0.5s ease;"
    ></p>

    <!-- Thin divider -->
    <div id="hero-divider" class="w-10 h-px bg-gray-200 dark:bg-gray-700 my-6 mx-auto" style="opacity: 0; transition: opacity 0.4s ease;"></div>

    <!-- Tagline -->
    <p
      id="hero-tagline"
      class="text-base sm:text-lg text-gray-400 dark:text-gray-500 mb-10 max-w-lg leading-relaxed mx-auto"
      data-i18n="home.tagline"
      style="opacity: 0; transform: translateY(10px); transition: opacity 0.5s ease 0.06s, transform 0.5s ease 0.06s;"
    ></p>

    <!-- Buttons + Social -->
    <div id="hero-buttons" style="opacity: 0; transform: translateY(10px); transition: opacity 0.5s ease, transform 0.5s ease;">
      <div class="flex flex-col sm:flex-row gap-3 mb-5 justify-center">
        <a
          href="#work"
          class="px-8 py-4 bg-black dark:bg-white text-white dark:text-black rounded-full font-semibold hover:bg-gray-800 dark:hover:bg-gray-100 transition-all duration-300 hover:scale-[1.02] shadow-md shadow-black/10 hover:shadow-lg hover:shadow-black/20 inline-block text-center"
          data-i18n="home.viewWork"
        >
          View Work
        </a>
        <a
          href="#contact"
          class="px-8 py-4 bg-transparent border border-gray-200 dark:border-gray-800 text-gray-900 dark:text-white rounded-full font-semibold hover:bg-gray-50 dark:hover:bg-white/5 transition-all duration-300 hover:scale-[1.02] inline-block text-center"
          data-i18n="home.contactMe"
        >
          Contact Me
        </a>
      </div>

      <!-- Social Links + CV -->
      <div class="flex gap-3 items-center justify-center">
        <div id="hero-social-links" class="flex gap-3">
          <!-- Social links will be inserted here by JavaScript -->
        </div>
        <div class="w-px h-5 bg-gray-200 dark:bg-gray-800 mx-1 shrink-0"></div>
        <a
          href="/CV.pdf"
          download
          class="w-10 h-10 flex items-center justify-center border border-gray-200 dark:border-gray-800 text-gray-500 dark:text-gray-400 rounded-full hover:bg-black dark:hover:bg-white hover:text-white dark:hover:text-black hover:border-black dark:hover:border-white transition-all duration-300 hover:-translate-y-1 hover:shadow-md"
          aria-label="Download CV"
          title="Download CV"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
          </svg>
        </a>
      </div>
    </div>

  </div>

  <!-- Scroll indicator -->
  <div
    id="scroll-indicator"
    class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-1.5 pointer-events-none"
    style="opacity: 0; transition: opacity 0.6s ease;"
  >
    <div class="w-px h-5 bg-gray-300 dark:bg-gray-700"></div>
    <svg class="w-3.5 h-3.5 text-gray-300 dark:text-gray-700 animate-bounce" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
    </svg>
  </div>
</section>

<style>
  @keyframes name-focus-in {
    from {
      filter: blur(14px);
      opacity: 0;
    }
    to {
      filter: blur(0px);
      opacity: 1;
    }
  }

  #name-line.name-focus-in {
    animation: name-focus-in 1.6s cubic-bezier(0.25, 0.46, 0.45, 0.94) both;
  }

  @keyframes blink {
    0%, 49% { opacity: 1; }
    50%, 100% { opacity: 0; }
  }

  /* Cursor starts hidden; only blinks after .active is added */
  .typing-cursor {
    opacity: 0;
    color: inherit;
    font-weight: 300;
  }
  .typing-cursor.active {
    animation: blink 1s infinite;
  }
</style>

<script>
  // Append text into .typing-text span
  async function typeWriterAppend(element: HTMLElement, text: string, speed: number = 50, useHTML: boolean = false): Promise<void> {
    return new Promise((resolve) => {
      const textSpan = element.querySelector('.typing-text') as HTMLElement;
      if (!textSpan) { resolve(); return; }
      let i = 0;
      const typing = setInterval(() => {
        if (i < text.length) {
          if (useHTML) textSpan.innerHTML += text.charAt(i);
          else textSpan.textContent += text.charAt(i);
          i++;
        } else {
          clearInterval(typing);
          resolve();
        }
      }, speed);
    });
  }

  // Clear + type
  async function typeWriter(element: HTMLElement, text: string, speed: number = 50, useHTML: boolean = false): Promise<void> {
    const textSpan = element.querySelector('.typing-text') as HTMLElement;
    if (textSpan) {
      if (useHTML) textSpan.innerHTML = '';
      else textSpan.textContent = '';
    }
    return typeWriterAppend(element, text, speed, useHTML);
  }

  let hasAnimated = false;

  async function animateHero() {
    if (hasAnimated) return;
    hasAnimated = true;

    const { translations } = await import('../data/translations');
    const currentLang = (localStorage.getItem('language') || 'en') as 'en' | 'es';
    const t = translations[currentLang];

    const nameLine    = document.getElementById('name-line')    as HTMLElement;
    const roleElement = document.getElementById('hero-role')    as HTMLElement;
    const divider     = document.getElementById('hero-divider') as HTMLElement;
    const taglineEl   = document.getElementById('hero-tagline') as HTMLElement;
    const buttonsEl   = document.getElementById('hero-buttons') as HTMLElement;
    const scrollInd   = document.getElementById('scroll-indicator') as HTMLElement;
    const cursorSpan  = nameLine?.querySelector('.typing-cursor') as HTMLElement;

    await new Promise(resolve => setTimeout(resolve, 150));

    // Reveal name with focus-in blur animation
    if (nameLine) {
      nameLine.style.opacity = '';
      nameLine.classList.add('name-focus-in');
    }
    if (cursorSpan) cursorSpan.classList.add('active');

    // Type first name
    if (nameLine) {
      await typeWriter(nameLine, 'Yewdiel', 60, true);
      await new Promise(resolve => setTimeout(resolve, 80));
      const textSpan = nameLine.querySelector('.typing-text');
      if (textSpan) textSpan.innerHTML += '<br>';
      await new Promise(resolve => setTimeout(resolve, 40));
    }

    // Type last name
    if (nameLine) {
      await typeWriterAppend(nameLine, 'Medina.', 60, true);
      await new Promise(resolve => setTimeout(resolve, 100));
    }

    // Reveal role
    if (roleElement) {
      roleElement.textContent = t.home.role;
      roleElement.style.opacity = '1';
      roleElement.style.transform = 'translateY(0)';
      await new Promise(resolve => setTimeout(resolve, 220));
    }

    // Reveal divider
    if (divider) {
      divider.style.opacity = '1';
      await new Promise(resolve => setTimeout(resolve, 150));
    }

    // Reveal tagline
    if (taglineEl) {
      taglineEl.textContent = t.home.tagline;
      taglineEl.style.opacity = '1';
      taglineEl.style.transform = 'translateY(0)';
      await new Promise(resolve => setTimeout(resolve, 250));
    }

    // Reveal buttons
    if (buttonsEl) {
      buttonsEl.style.opacity = '1';
      buttonsEl.style.transform = 'translateY(0)';
    }

    // Scroll indicator appears last
    await new Promise(resolve => setTimeout(resolve, 700));
    if (scrollInd) scrollInd.style.opacity = '1';
  }

  window.addEventListener('DOMContentLoaded', () => {
    animateHero();
    loadSocialLinks();

    // Hide scroll indicator when user scrolls
    const scrollInd = document.getElementById('scroll-indicator');
    if (scrollInd) {
      window.addEventListener('scroll', () => {
        scrollInd.style.opacity = window.scrollY > 60 ? '0' : '1';
      }, { passive: true });
    }
  });

  async function loadSocialLinks() {
    try {
      const { social } = await import('../data/translations');
      renderSocialLinks(social);
    } catch (error) {
      console.error('Error loading social links:', error);
    }
  }

  function renderSocialLinks(social: any) {
    const container = document.getElementById('hero-social-links');
    if (!container) return;

    const cls = 'w-10 h-10 flex items-center justify-center border border-gray-200 dark:border-gray-800 text-gray-500 dark:text-gray-400 rounded-full hover:bg-black dark:hover:bg-white hover:text-white dark:hover:text-black hover:border-black dark:hover:border-white transition-all duration-300 hover:-translate-y-1 hover:shadow-md';
    const ico = 'w-5 h-5';
    const links = [];

    if (social.github) {
      links.push(`
        <a href="${social.github}" target="_blank" rel="noopener noreferrer" class="${cls}" aria-label="GitHub">
          <svg class="${ico}" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
          </svg>
        </a>
      `);
    }

    if (social.linkedin) {
      links.push(`
        <a href="${social.linkedin}" target="_blank" rel="noopener noreferrer" class="${cls}" aria-label="LinkedIn">
          <svg class="${ico}" fill="currentColor" viewBox="0 0 24 24">
            <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
          </svg>
        </a>
      `);
    }

    if (social.twitter) {
      links.push(`
        <a href="${social.twitter}" target="_blank" rel="noopener noreferrer" class="${cls}" aria-label="Twitter">
          <svg class="${ico}" fill="currentColor" viewBox="0 0 24 24">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
          </svg>
        </a>
      `);
    }

    if (social.email) {
      links.push(`
        <a href="mailto:${social.email}" class="${cls}" aria-label="Email">
          <svg class="${ico}" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
          </svg>
        </a>
      `);
    }

    container.innerHTML = links.join('');
  }

  window.addEventListener('languageChange', async (event: any) => {
    const { translations } = event.detail;
    const nameLine    = document.getElementById('name-line')    as HTMLElement;
    const roleElement = document.getElementById('hero-role')    as HTMLElement;
    const divider     = document.getElementById('hero-divider') as HTMLElement;
    const taglineEl   = document.getElementById('hero-tagline') as HTMLElement;
    const buttonsEl   = document.getElementById('hero-buttons') as HTMLElement;
    const scrollInd   = document.getElementById('scroll-indicator') as HTMLElement;

    // Hide everything
    if (roleElement)  { roleElement.style.opacity = '0'; roleElement.style.transform = 'translateY(10px)'; }
    if (taglineEl)    { taglineEl.style.opacity = '0';   taglineEl.style.transform = 'translateY(10px)'; }
    if (divider)      divider.style.opacity = '0';
    if (buttonsEl)    { buttonsEl.style.opacity = '0';   buttonsEl.style.transform = 'translateY(10px)'; }
    if (scrollInd)    scrollInd.style.opacity = '0';

    // Clear name
    if (nameLine) {
      const textSpan   = nameLine.querySelector('.typing-text');
      const cursorSpan = nameLine.querySelector('.typing-cursor');
      if (textSpan) textSpan.innerHTML = '';
      if (cursorSpan) cursorSpan.classList.remove('active');
      nameLine.style.opacity = '0';
    }

    // Update button text
    const viewWorkBtn = document.querySelector('[data-i18n="home.viewWork"]');
    const contactBtn  = document.querySelector('[data-i18n="home.contactMe"]');
    if (viewWorkBtn) viewWorkBtn.textContent = translations.home.viewWork;
    if (contactBtn)  contactBtn.textContent  = translations.home.contactMe;

    // Re-run animation
    hasAnimated = false;
    await new Promise(resolve => setTimeout(resolve, 100));
    animateHero();
  });
</script>
