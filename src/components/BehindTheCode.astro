---
// Behind the Code - Easter Egg
---

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500&display=swap" rel="stylesheet">

<!-- Behind the Code Modal -->
<div
  id="behind-modal"
  class="fixed inset-0 z-[100] hidden items-center justify-center p-4 sm:p-6"
>
  <!-- Backdrop -->
  <div id="behind-backdrop" class="absolute inset-0 bg-black/80 backdrop-blur-sm"></div>

  <!-- Panel -->
  <div
    id="behind-panel"
    class="relative bg-[#111] border border-white/10 rounded-2xl max-w-2xl w-full max-h-[88vh] overflow-hidden shadow-2xl"
  >
    <!-- Header -->
    <div class="flex items-start justify-between px-8 pt-8 pb-6 border-b border-white/8">
      <div>
        <p class="text-xs text-white/35 tracking-widest uppercase mb-3 font-normal" data-i18n="behind.unlocked">Easter Egg Unlocked</p>
        <h2 class="text-3xl font-medium text-white leading-tight" data-i18n="behind.title">Behind the Code</h2>
        <p class="text-base text-white/45 mt-1.5 font-normal" data-i18n="behind.subtitle">How and why this portfolio was crafted</p>
      </div>
      <button
        id="behind-close"
        class="w-8 h-8 flex items-center justify-center rounded-full text-white/35 hover:text-white hover:bg-white/10 transition-all duration-200 shrink-0 mt-1"
        aria-label="Close"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
    </div>

    <!-- Content -->
    <div class="px-8 py-7 overflow-y-auto max-h-[calc(88vh-130px)] custom-scrollbar space-y-9">

      <!-- Tech Stack -->
      <div>
        <p class="text-sm font-medium text-white/50 mb-4" data-i18n="behind.techStack">Stack</p>
        <div class="grid grid-cols-3 gap-3">
          <!-- Astro -->
          <div class="flex flex-col gap-3 p-4 rounded-xl border border-white/8 hover:border-white/14 bg-white/3 hover:bg-white/5 transition-all duration-200">
            <svg class="w-6 h-6 text-[#FF5D01]" fill="currentColor" viewBox="0 0 256 366">
              <path d="M182.022 9.147c2.982 3.702 4.502 8.697 7.543 18.687L256 246.074a276.467 276.467 0 0 0-79.426-26.891L133.318 73.008a5.63 5.63 0 0 0-10.802.017L79.784 219.11A276.453 276.453 0 0 0 0 246.04L66.76 27.783c3.051-9.972 4.577-14.959 7.559-18.654a24.541 24.541 0 0 1 9.946-7.358C88.67 0 93.885 0 104.314 0h47.683c10.443 0 15.664 0 20.074 1.774a24.545 24.545 0 0 1 9.95 7.373Z"/>
            </svg>
            <div>
              <div class="text-sm font-medium text-white">Astro</div>
              <div class="text-xs text-white/35 mt-0.5">v5.15.3</div>
            </div>
          </div>
          <!-- Tailwind -->
          <div class="flex flex-col gap-3 p-4 rounded-xl border border-white/8 hover:border-white/14 bg-white/3 hover:bg-white/5 transition-all duration-200">
            <svg class="w-6 h-6 text-[#06B6D4]" fill="currentColor" viewBox="0 0 54 33">
              <path fill-rule="evenodd" clip-rule="evenodd" d="M27 0c-7.2 0-11.7 3.6-13.5 10.8 2.7-3.6 5.85-4.95 9.45-4.05 2.054.513 3.522 2.004 5.147 3.653C30.744 13.09 33.808 16.2 40.5 16.2c7.2 0 11.7-3.6 13.5-10.8-2.7 3.6-5.85 4.95-9.45 4.05-2.054-.513-3.522-2.004-5.147-3.653C36.756 3.11 33.692 0 27 0zM13.5 16.2C6.3 16.2 1.8 19.8 0 27c2.7-3.6 5.85-4.95 9.45-4.05 2.054.514 3.522 2.004 5.147 3.653C17.244 29.29 20.308 32.4 27 32.4c7.2 0 11.7-3.6 13.5-10.8-2.7 3.6-5.85 4.95-9.45 4.05-2.054-.513-3.522-2.004-5.147-3.653C23.256 19.31 20.192 16.2 13.5 16.2z"/>
            </svg>
            <div>
              <div class="text-sm font-medium text-white">Tailwind CSS</div>
              <div class="text-xs text-white/35 mt-0.5">v4</div>
            </div>
          </div>
          <!-- TypeScript -->
          <div class="flex flex-col gap-3 p-4 rounded-xl border border-white/8 hover:border-white/14 bg-white/3 hover:bg-white/5 transition-all duration-200">
            <svg class="w-6 h-6 text-[#3178C6]" fill="currentColor" viewBox="0 0 256 256">
              <path d="M20 0h216c11.046 0 20 8.954 20 20v216c0 11.046-8.954 20-20 20H20c-11.046 0-20-8.954-20-20V20C0 8.954 8.954 0 20 0Z"/>
              <path fill="#fff" d="m150.518 200.475 27.368 15.82v-50.826l-27.368-15.884zm8.89-79.089 27.368 15.82V86.38l-27.368-15.82zm-60.73 0-27.368 15.82V86.38l27.368-15.82zm-8.89 63.205v31.643l27.368 15.884V150.3l-27.368-15.884z"/>
            </svg>
            <div>
              <div class="text-sm font-medium text-white">TypeScript</div>
              <div class="text-xs text-white/35 mt-0.5">Type safety</div>
            </div>
          </div>
        </div>
      </div>

      <!-- Why -->
      <div>
        <p class="text-sm font-medium text-white/50 mb-5" data-i18n="behind.whyTitle">Why this stack</p>
        <div class="space-y-4">
          <div class="flex gap-4">
            <div class="w-px bg-white/10 shrink-0 mx-1"></div>
            <div>
              <p class="text-base font-medium text-white mb-1" data-i18n="behind.why1Title">Zero-JS by default</p>
              <p class="text-sm text-white/45 leading-relaxed font-normal" data-i18n="behind.why1Desc">Astro ships no JavaScript unless you opt in. Every section is a static component — fast loads, great SEO, and full control over what actually runs in the browser.</p>
            </div>
          </div>
          <div class="flex gap-4">
            <div class="w-px bg-white/10 shrink-0 mx-1"></div>
            <div>
              <p class="text-base font-medium text-white mb-1" data-i18n="behind.why2Title">CSS-first styling</p>
              <p class="text-sm text-white/45 leading-relaxed font-normal" data-i18n="behind.why2Desc">Tailwind v4 drops the JS config file entirely — styles are defined in CSS via @theme. Combined with Astro's scoped styles, every component owns its appearance without conflicts.</p>
            </div>
          </div>
          <div class="flex gap-4">
            <div class="w-px bg-white/10 shrink-0 mx-1"></div>
            <div>
              <p class="text-base font-medium text-white mb-1" data-i18n="behind.why3Title">Typed content layer</p>
              <p class="text-sm text-white/45 leading-relaxed font-normal" data-i18n="behind.why3Desc">All projects, skills and copy live in TypeScript data files. No CMS, no API calls at runtime — just typed objects that get validated at build time.</p>
            </div>
          </div>
        </div>
      </div>

      <!-- How -->
      <div>
        <p class="text-sm font-medium text-white/50 mb-5" data-i18n="behind.howTitle">How it was built</p>
        <div class="space-y-4">
          <div class="flex gap-4">
            <div class="w-px bg-white/10 shrink-0 mx-1"></div>
            <div>
              <p class="text-base font-medium text-white mb-1" data-i18n="behind.how1Title">Liquid glass navbar</p>
              <p class="text-sm text-white/45 leading-relaxed font-normal" data-i18n="behind.how1Desc">An SVG feDisplacementMap filter creates the lens-distortion on the pill. Layered inset box-shadows simulate the specular highlights of glass in both light and dark modes — without a single image asset.</p>
            </div>
          </div>
          <div class="flex gap-4">
            <div class="w-px bg-white/10 shrink-0 mx-1"></div>
            <div>
              <p class="text-base font-medium text-white mb-1" data-i18n="behind.how2Title">Hero entrance</p>
              <p class="text-sm text-white/45 leading-relaxed font-normal" data-i18n="behind.how2Desc">The name types in with a custom async function while a CSS blur-to-sharp animation runs in parallel — giving the impression of a camera coming into focus as each character appears.</p>
            </div>
          </div>
          <div class="flex gap-4">
            <div class="w-px bg-white/10 shrink-0 mx-1"></div>
            <div>
              <p class="text-base font-medium text-white mb-1" data-i18n="behind.how3Title">Dark mode</p>
              <p class="text-sm text-white/45 leading-relaxed font-normal" data-i18n="behind.how3Desc">A .dark class on &lt;html&gt; drives all theme changes via a Tailwind custom variant. Dark overrides for Astro-scoped components live in is:global blocks to bypass the component hash.</p>
            </div>
          </div>
          <div class="flex gap-4">
            <div class="w-px bg-white/10 shrink-0 mx-1"></div>
            <div>
              <p class="text-base font-medium text-white mb-1" data-i18n="behind.how4Title">i18n without a framework</p>
              <p class="text-sm text-white/45 leading-relaxed font-normal" data-i18n="behind.how4Desc">Translations are a plain TypeScript object keyed by locale. A custom event dispatcher notifies every component when the language switches, so the whole page re-renders in place.</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Palette + Footer -->
      <div class="space-y-6">
        <div>
          <p class="text-sm font-medium text-white/50 mb-4" data-i18n="behind.colorPalette">Palette</p>
          <div class="flex gap-2">
            <div class="flex-1 text-center">
              <div class="h-9 rounded-lg bg-black border border-white/10 mb-1.5"></div>
              <div class="text-xs font-mono text-white/25">#000</div>
            </div>
            <div class="flex-1 text-center">
              <div class="h-9 rounded-lg bg-white mb-1.5"></div>
              <div class="text-xs font-mono text-white/25">#FFF</div>
            </div>
            <div class="flex-1 text-center">
              <div class="h-9 rounded-lg bg-[#0D0D0D] border border-white/10 mb-1.5"></div>
              <div class="text-xs font-mono text-white/25">#0D0D</div>
            </div>
            <div class="flex-1 text-center">
              <div class="h-9 rounded-lg bg-[#2a2a2a] mb-1.5"></div>
              <div class="text-xs font-mono text-white/25">#2a2a</div>
            </div>
          </div>
        </div>

        <div class="pt-1 pb-2 flex items-center justify-between border-t border-white/6">
          <div class="text-xs text-white/22 font-normal" data-i18n="behind.builtWith">Built with passion and precision</div>
          <div class="text-xs text-white/22 font-normal">
            <kbd class="px-1.5 py-0.5 bg-white/7 rounded text-white/35 font-mono text-[11px]">Ctrl+Shift+D</kbd>
            <span class="ml-1" data-i18n="behind.togglePanel">to toggle</span>
          </div>
        </div>
      </div>

    </div>
  </div>
</div>

<style>
  #behind-modal {
    font-family: 'DM Sans', sans-serif;
  }

  @keyframes modal-backdrop-in {
    from { opacity: 0; }
    to   { opacity: 1; }
  }
  @keyframes modal-panel-in {
    from { opacity: 0; transform: translateY(16px) scale(0.98); }
    to   { opacity: 1; transform: translateY(0) scale(1); }
  }

  #behind-modal.flex #behind-backdrop {
    animation: modal-backdrop-in 0.2s ease-out both;
  }
  #behind-modal.flex #behind-panel {
    animation: modal-panel-in 0.28s cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  .custom-scrollbar::-webkit-scrollbar { width: 4px; }
  .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
  .custom-scrollbar::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.12); border-radius: 4px; }
  .custom-scrollbar::-webkit-scrollbar-thumb:hover { background: rgba(255,255,255,0.2); }

  kbd { font-family: 'DM Sans', sans-serif; }
</style>

<script>
  const behindModal = document.getElementById('behind-modal');
  const behindClose = document.getElementById('behind-close');
  
  let konamiCode = '';
  const konamiSequence = 'dev'; // Type "dev"
  
  // Konami code / Secret key combination
  window.addEventListener('keydown', (e) => {
    // Ctrl + Shift + D
    if (e.ctrlKey && e.shiftKey && e.key === 'D') {
      e.preventDefault();
      toggleModal();
      return;
    }

    // Secret word "dev"
    if (e.key.length === 1) {
      konamiCode += e.key.toLowerCase();
      
      if (konamiCode.length > konamiSequence.length) {
        konamiCode = konamiCode.slice(-konamiSequence.length);
      }
      
      if (konamiCode === konamiSequence) {
        konamiCode = '';
        openModal();
      }
    }
  });

  function openModal() {
    if (behindModal) {
      behindModal.classList.remove('hidden');
      behindModal.classList.add('flex');
      document.body.style.overflow = 'hidden';
      
      // Play a subtle notification sound (optional)
      playNotification();
    }
  }

  function closeModal() {
    if (behindModal) {
      behindModal.classList.add('hidden');
      behindModal.classList.remove('flex');
      document.body.style.overflow = '';
    }
  }

  function toggleModal() {
    if (behindModal?.classList.contains('hidden')) {
      openModal();
    } else {
      closeModal();
    }
  }

  // Close button
  behindClose?.addEventListener('click', closeModal);

  // Close on background click
  behindModal?.addEventListener('click', (e) => {
    if (e.target === behindModal) {
      closeModal();
    }
  });

  // Close on Escape key
  window.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !behindModal?.classList.contains('hidden')) {
      closeModal();
    }
  });

  // Optional: Play a subtle notification sound
  function playNotification() {
    const audioContext = new (window.AudioContext || (window as any).webkitAudioContext)();
    const oscillator = audioContext.createOscillator();
    const gainNode = audioContext.createGain();
    
    oscillator.connect(gainNode);
    gainNode.connect(audioContext.destination);
    
    oscillator.frequency.value = 800;
    oscillator.type = 'sine';
    
    gainNode.gain.setValueAtTime(0.3, audioContext.currentTime);
    gainNode.gain.exponentialRampToValueAtTime(0.01, audioContext.currentTime + 0.3);
    
    oscillator.start(audioContext.currentTime);
    oscillator.stop(audioContext.currentTime + 0.3);
  }

  // Language change handler
  window.addEventListener('languageChange', async (e: Event) => {
    const customEvent = e as CustomEvent;
    const { translations } = customEvent.detail;
    
    // Update all elements with data-i18n attribute inside the modal
    behindModal?.querySelectorAll('[data-i18n]').forEach((element) => {
      const key = element.getAttribute('data-i18n');
      if (key) {
        const keys = key.split('.');
        let value: any = translations;
        for (const k of keys) {
          value = value[k];
        }
        if (value) {
          element.textContent = value;
        }
      }
    });
  });

  // Hint in console
  console.log('%c[DEV] Easter Egg Alert!', 'color: #ffffff; font-size: 20px; font-weight: bold;');
  console.log('%cTry typing "dev" or press Ctrl+Shift+D', 'color: #aaaaaa; font-size: 14px;');
  console.log('%cBuilt with passion by Yewdiel Medina', 'color: #666; font-size: 12px;');
</script>
