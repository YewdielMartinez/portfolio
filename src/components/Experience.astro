---

<!--
  Experience — Pinned scroll narrative
  Section height = N × 100vh (set by JS after data loads)
  Sticky inner stays fixed while user scrolls through each "chapter"
-->
<section
  id="experience"
  class="relative dark:bg-[rgb(38,38,36)]"
>
  <div
    id="exp-sticky"
    class="h-screen flex flex-col overflow-hidden px-6 sm:px-10 lg:px-20"
  >

    <!-- ── Top bar: large counter (left) + step tracker (right) ── -->
    <div class="pt-8 pb-0 flex items-start justify-between shrink-0">
      <div class="flex flex-col">
        <span class="text-[9px] font-medium tracking-[0.28em] uppercase text-gray-300 dark:text-gray-600 mb-1">Experience</span>
        <div class="flex items-baseline gap-3">
          <span
            id="exp-num-current"
            class="font-normal tabular-nums text-gray-900 dark:text-white"
            style="font-size: clamp(3rem, 6.5vw, 6rem); letter-spacing: -0.05em; line-height: 1;"
          >01</span>
          <span class="text-gray-200 dark:text-gray-700" style="font-size: clamp(1rem, 2vw, 1.6rem);" aria-hidden="true">—</span>
          <span
            id="exp-num-total"
            class="font-normal tabular-nums text-gray-200 dark:text-gray-700"
            style="font-size: clamp(1.2rem, 2.5vw, 2rem); letter-spacing: -0.04em; line-height: 1;"
          >03</span>
        </div>
      </div>
      <div id="exp-steps" class="flex items-center gap-5 sm:gap-8 mt-3"></div>
    </div>

    <!-- ── Ghost background text ── -->
    <div
      class="absolute inset-0 flex items-end pointer-events-none select-none overflow-hidden"
      aria-hidden="true"
    >
      <span
        id="exp-bg-word"
        class="font-normal text-gray-900 dark:text-white leading-none"
        style="
          font-size: clamp(9rem, 22vw, 22rem);
          letter-spacing: -0.05em;
          opacity: 0.04;
          padding-left: 0.5vw;
          padding-bottom: 0;
          white-space: nowrap;
          will-change: transform;
        "
      ></span>
    </div>

    <!-- ── Progress line ── -->
    <div class="relative shrink-0 mt-auto" style="height: 1px; margin-bottom: 0;">
      <div class="absolute inset-0 bg-gray-100 dark:bg-gray-700/40"></div>
      <div
        id="exp-progress-line"
        class="absolute inset-y-0 left-0 bg-gray-400 dark:bg-gray-500"
        style="width: 0%; transition: width 0.6s cubic-bezier(0.4, 0, 0.2, 1);"
      ></div>
    </div>

    <!-- ── Main panel ── -->
    <div id="exp-panel" class="relative z-10 pb-14 pt-10 flex-1 flex flex-col justify-center">
      <div class="max-w-6xl w-full">

        <!-- Two-column grid -->
        <div class="grid grid-cols-1 lg:grid-cols-[1fr_1fr] gap-6 lg:gap-20">

          <!-- Left: company + role + year -->
          <div>
            <h3
              id="exp-company-name"
              class="font-normal text-gray-900 dark:text-white mb-6"
              style="font-size: clamp(2.8rem, 5.5vw, 5.5rem); letter-spacing: -0.04em; line-height: 1.0;"
            ></h3>
            <div class="flex items-center gap-3">
              <p id="exp-role-label"
                class="text-xs font-medium tracking-[0.2em] uppercase text-gray-400 dark:text-gray-500"
              ></p>
              <span class="text-gray-200 dark:text-gray-700 text-sm" aria-hidden="true">·</span>
              <p id="exp-year-label"
                class="text-xs text-gray-300 dark:text-gray-600 tabular-nums"
              ></p>
            </div>
          </div>

          <!-- Right: description -->
          <div class="lg:border-l lg:border-gray-100 dark:lg:border-gray-700/40 lg:pl-10 flex items-start">
            <p id="exp-desc-text"
              class="text-lg text-gray-500 dark:text-gray-400 leading-relaxed"
            ></p>
          </div>

        </div>
      </div>
    </div>

    <!-- ── Scroll hint (first experience only) ── -->
    <div
      id="exp-scroll-hint"
      class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2"
      aria-hidden="true"
    >
      <span class="text-[9px] tracking-[0.2em] uppercase text-gray-300 dark:text-gray-600">Scroll</span>
      <div class="w-px h-8 bg-linear-to-b from-gray-300 dark:from-gray-600 to-transparent"></div>
    </div>

  </div>
</section>

<style>
  /* Panel initial state — JS sets via gsap.set */
  #exp-panel { will-change: opacity, transform; }
  #exp-bg-word { will-change: opacity, transform; }

  /* Step items */
  .exp-step {
    display: flex;
    align-items: center;
    gap: 6px;
    cursor: default;
    transition: opacity 0.4s ease;
  }
  .exp-step .step-num {
    font-size: 9px;
    font-weight: 500;
    letter-spacing: 0.1em;
    font-variant-numeric: tabular-nums;
    transition: color 0.4s ease;
  }
  .exp-step .step-company {
    display: none;
    font-size: 9px;
    letter-spacing: 0.08em;
    transition: color 0.4s ease;
    max-width: 90px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  @media (min-width: 640px) {
    .exp-step .step-company { display: block; }
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  let allExp: any[] = [];
  let currentIdx = -1;

  // ── Build step tracker ──────────────────────────────────────
  function buildSteps(experiences: any[]) {
    const container = document.getElementById('exp-steps');
    if (!container) return;

    container.innerHTML = experiences.map((exp, i) => `
      <div class="exp-step" data-idx="${i}">
        <span class="step-num" style="color: rgb(209 213 219)">
          ${String(i + 1).padStart(2, '0')}
        </span>
        <span class="step-company" style="color: rgb(209 213 219)">
          ${exp.company}
        </span>
      </div>
    `).join('');
  }

  function updateSteps(active: number) {
    document.querySelectorAll<HTMLElement>('.exp-step').forEach((el, i) => {
      const num = el.querySelector<HTMLElement>('.step-num');
      const label = el.querySelector<HTMLElement>('.step-company');
      const isActive = i === active;
      const isPast   = i < active;

      const activeColor = document.documentElement.classList.contains('dark')
        ? 'rgb(255 255 255)'
        : 'rgb(17 24 39)';
      const pastColor   = document.documentElement.classList.contains('dark')
        ? 'rgb(100 100 98)'
        : 'rgb(156 163 175)';
      const futureColor = document.documentElement.classList.contains('dark')
        ? 'rgb(70 70 68)'
        : 'rgb(229 231 235)';

      const color = isActive ? activeColor : isPast ? pastColor : futureColor;
      if (num)   num.style.color   = color;
      if (label) label.style.color = color;
    });

    const line = document.getElementById('exp-progress-line');
    if (line && allExp.length > 1) {
      const pct = ((active + 1) / allExp.length) * 100;
      line.style.width = `${pct}%`;
    }
  }

  // ── Show an experience ──────────────────────────────────────
  function showExp(i: number, instant = false) {
    if (i === currentIdx) return;
    const prev = currentIdx;
    currentIdx = i;
    const exp = allExp[i];

    const panel   = document.getElementById('exp-panel');
    const bgWord  = document.getElementById('exp-bg-word');
    const hint    = document.getElementById('exp-scroll-hint');

    const updateDOM = () => {
      const name = document.getElementById('exp-company-name');
      const role = document.getElementById('exp-role-label');
      const year = document.getElementById('exp-year-label');
      const desc = document.getElementById('exp-desc-text');
      const numCurrent = document.getElementById('exp-num-current');

      if (numCurrent) numCurrent.textContent = String(i + 1).padStart(2, '0');
      if (name) name.textContent = exp.company;
      if (role) role.textContent = exp.position;
      if (year) year.textContent = exp.year;
      if (desc) desc.textContent = exp.description;
      if (bgWord) bgWord.textContent = exp.company.split(' ')[0];
      updateSteps(i);
    };

    if (hint) {
      gsap.to(hint, { opacity: i === 0 ? 1 : 0, duration: 0.3, overwrite: 'auto' });
    }

    if (instant) {
      updateDOM();
      if (panel)  gsap.set(panel,  { opacity: 1, y: 0 });
      if (bgWord) gsap.set(bgWord, { opacity: 1 });
      return;
    }

    const direction = i > prev ? 1 : -1;

    gsap.timeline({ defaults: { overwrite: 'auto' } })
      .to(panel!,             { opacity: 0, y: -14 * direction, duration: 0.22, ease: 'power2.in' }, 0)
      .to(bgWord!,            { opacity: 0, duration: 0.18 }, 0)
      .to('#exp-num-current', { opacity: 0, y: -8 * direction, duration: 0.18, ease: 'power2.in' }, 0)
      .call(updateDOM)
      .set(panel!,             { y: 14 * direction })
      .set('#exp-num-current', { y: 8 * direction })
      .to(panel!,              { opacity: 1, y: 0, duration: 0.45, ease: 'power3.out' })
      .to(bgWord!,             { opacity: 1, duration: 0.4, ease: 'power2.out' }, '-=0.3')
      .to('#exp-num-current',  { opacity: 1, y: 0, duration: 0.35, ease: 'power3.out' }, '-=0.35');
  }

  // ── Setup scroll (GSAP pin on #exp-sticky) ─────────────────
  function setupScroll(experiences: any[]) {
    allExp = experiences;
    if (!experiences.length) return;

    const count = experiences.length;
    const numTotal = document.getElementById('exp-num-total');
    if (numTotal) numTotal.textContent = String(count).padStart(2, '0');

    buildSteps(experiences);
    showExp(0, true);

    // Kill previous pin trigger on language switch
    ScrollTrigger.getById('exp-scroll')?.kill();

    ScrollTrigger.create({
      id: 'exp-scroll',
      trigger: '#exp-sticky',
      start: 'top top',
      end: () => `+=${count * window.innerHeight}`,
      pin: true,
      pinSpacing: true,
      invalidateOnRefresh: true,
      onLeaveBack: () => showExp(0),
      onUpdate: (self) => {
        const idx = Math.min(Math.floor(self.progress * count), count - 1);
        if (idx !== currentIdx) showExp(idx);
      },
    });

    ScrollTrigger.refresh();
  }

  // ── Entrance animation for the header bar ──────────────────
  function initHeaderEntrance() {
    gsap.from('#exp-steps, #experience > div > div:first-child', {
      opacity: 0,
      y: -10,
      duration: 0.6,
      ease: 'power2.out',
      overwrite: 'auto',
      scrollTrigger: {
        trigger: '#experience',
        start: 'top 75%',
        once: true,
      },
    });
  }

  // ── Load data ───────────────────────────────────────────────
  async function loadExperience() {
    const { experience } = await import('../data/experience');
    const lang = (localStorage.getItem('language') || 'en') as 'en' | 'es';
    setupScroll(experience[lang]);
    initHeaderEntrance();
  }

  // ── Language change ─────────────────────────────────────────
  window.addEventListener('languageChange', async (event: any) => {
    const { lang } = event.detail;
    const { experience } = await import('../data/experience');
    currentIdx = -1;
    setupScroll(experience[lang as 'en' | 'es']);
  });

  document.addEventListener('DOMContentLoaded', loadExperience);
</script>
