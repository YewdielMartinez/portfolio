---
// Footer
---

<footer class="border-t border-gray-200 dark:border-gray-700 py-8 px-4 sm:px-8 lg:px-16 dark:bg-[rgb(38,38,36)]">
  <div class="max-w-7xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-5">

    <!-- Left: name + meta -->
    <div class="flex flex-col sm:flex-row items-center gap-2 sm:gap-3 text-sm text-gray-400 dark:text-gray-600">
      <span class="font-medium text-gray-700 dark:text-gray-300">Yewdiel Medina</span>
      <span class="hidden sm:block opacity-40">·</span>
      <span id="footer-year"></span>
      <span class="hidden sm:block opacity-40">·</span>
      <span>
        <span data-i18n-footer="builtWith">Built with</span>
        <a
          href="https://astro.build"
          target="_blank"
          rel="noopener noreferrer"
          class="ml-1 hover:text-gray-900 dark:hover:text-white transition-colors duration-200"
        >Astro</a>
      </span>
    </div>

    <!-- Right: social icons -->
    <div id="footer-social-links" class="flex items-center gap-2">
      <!-- Populated by JS -->
    </div>

  </div>
</footer>

<script>
  // Year
  const yearEl = document.getElementById('footer-year');
  if (yearEl) yearEl.textContent = `© ${new Date().getFullYear()}`;

  // Social icons
  async function loadFooterSocial() {
    try {
      const { social } = await import('../data/translations');
      const container = document.getElementById('footer-social-links');
      if (!container) return;

      const cls =
        'w-8 h-8 flex items-center justify-center border border-gray-200 dark:border-gray-800 ' +
        'text-gray-400 dark:text-gray-600 rounded-full ' +
        'hover:bg-black dark:hover:bg-white hover:text-white dark:hover:text-black ' +
        'hover:border-black dark:hover:border-white transition-all duration-200 hover:-translate-y-0.5';
      const ico = 'w-3.5 h-3.5';

      const links: string[] = [];

      if (social.github) {
        links.push(`
          <a href="${social.github}" target="_blank" rel="noopener noreferrer" class="${cls}" aria-label="GitHub">
            <svg class="${ico}" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
            </svg>
          </a>
        `);
      }

      if (social.linkedin) {
        links.push(`
          <a href="${social.linkedin}" target="_blank" rel="noopener noreferrer" class="${cls}" aria-label="LinkedIn">
            <svg class="${ico}" fill="currentColor" viewBox="0 0 24 24">
              <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
            </svg>
          </a>
        `);
      }

      if (social.twitter) {
        links.push(`
          <a href="${social.twitter}" target="_blank" rel="noopener noreferrer" class="${cls}" aria-label="Twitter / X">
            <svg class="${ico}" fill="currentColor" viewBox="0 0 24 24">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
            </svg>
          </a>
        `);
      }

      if (social.email) {
        links.push(`
          <a href="mailto:${social.email}" class="${cls}" aria-label="Email">
            <svg class="${ico}" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
          </a>
        `);
      }

      container.innerHTML = links.join('');
    } catch (err) {
      console.error('Footer social error:', err);
    }
  }

  // i18n support
  const builtWithMap: Record<string, string> = { en: 'Built with', es: 'Hecho con' };
  function updateFooterLang(lang: string) {
    const el = document.querySelector('[data-i18n-footer="builtWith"]');
    if (el) el.textContent = builtWithMap[lang] ?? builtWithMap['en'];
  }
  window.addEventListener('languageChange', (e: any) => updateFooterLang(e.detail.lang));

  window.addEventListener('DOMContentLoaded', () => {
    loadFooterSocial();
    const lang = localStorage.getItem('language') || 'en';
    updateFooterLang(lang);
  });
</script>
